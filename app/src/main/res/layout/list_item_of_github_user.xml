<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="data"
            type="com.example.userapp.core.data.dto.user.GithubUser" />

        <variable
            name="listener"
            type="com.example.userapp.core.data.dto.user.GithubUserItemClickListener" />
    </data>

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@color/red"
    android:layout_marginTop="8dp"
    android:onClick="@{(view) -> listener.onUserClicked(view, data)}">

    <ImageView
        android:id="@+id/userImageView"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:contentDescription="@null"
        app:roundImageUrl="@{data.avatarUrl}"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:textColor="@color/white"
        tools:text="User Name"
        android:textStyle="bold"
        android:textSize="20sp"
        android:text="@{data.login}"/>

</androidx.constraintlayout.widget.ConstraintLayout>
</layout>
